{
  "name": "@aether/shared",
  "version": "1.0.0",
  "description": "Shared types and the multi-game template engine for Aether",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "test": "npm run build && vitest run"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
