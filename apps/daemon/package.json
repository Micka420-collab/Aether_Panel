{
  "name": "@aether/daemon",
  "version": "1.0.0",
  "description": "Aether node daemon — controls Docker game-server containers, streams consoles & stats.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "npm run build && vitest run"
  },
  "dependencies": {
    "@aether/shared": "*",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "rcon-client": "^4.2.5",
    "ssh2": "^1.16.0",
    "tar-fs": "^3.0.6",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.31",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/ssh2": "^1.15.1",
    "@types/tar-fs": "^2.0.4",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
