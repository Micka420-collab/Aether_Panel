# ─────────────────────────────────────────────────────────────
#  Aether — example environment. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# === Panel (apps/panel) ===
# PostgreSQL connection string
DATABASE_URL="postgresql://aether:aether@localhost:5432/aether?schema=public"

# Public URL of the panel (no trailing slash)
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth — generate with: openssl rand -base64 48
AUTH_SECRET="change-me-please-generate-a-long-random-string"
# JWT used for the public/launcher API — generate another secret
API_JWT_SECRET="change-me-too-another-random-string"

# Default game node the daemon runs on (the local Ubuntu box by default)
DEFAULT_NODE_FQDN="localhost"

# === Daemon (apps/daemon) ===
# Port the daemon listens on (panel <-> daemon control channel)
DAEMON_PORT="8080"
# Shared secret between panel and daemon (Bearer token). MUST match the node's token.
DAEMON_TOKEN="change-me-shared-secret-between-panel-and-daemon"
# Where the daemon stores per-server volumes on the host
DAEMON_DATA_DIR="/var/lib/aether/volumes"
# Docker socket (Linux). On Windows for dev: npipe:////./pipe/docker_engine
DOCKER_SOCKET="/var/run/docker.sock"

# Host IP advertised to players for server connections
NODE_PUBLIC_IP="127.0.0.1"

# === Backups (optional, S3-compatible: AWS S3 / R2 / B2 / MinIO / Wasabi) ===
# Leave S3_ENDPOINT empty to keep backups local-only (the daemon stays dormant
# on S3). When set, every backup is also copied off-site and can be restored even
# if the node's local disk is lost.
S3_ENDPOINT=""                 # e.g. https://<accountid>.r2.cloudflarestorage.com
S3_REGION="auto"
S3_BUCKET="aether-backups"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_FORCE_PATH_STYLE="1"        # 1 = path-style (portable); set 0 for virtual-host style

# === Payments — Stripe card top-ups (optional) ===
# Dormant until STRIPE_SECRET_KEY is set: the billing API returns 503 and no card
# UI renders. Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""           # sk_live_… or sk_test_…
# Endpoint signing secret from the Stripe webhook you point at
# <APP_URL>/api/billing/stripe-webhook (event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=""       # whsec_…

# === Launcher / Microsoft OAuth (optional, for MC launcher auth) ===
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""

# === Free subdomains (optional) ===
# When set, users can claim "<sub>.<DOMAIN_BASE>" for their servers; the panel
# writes A + SRV records via the DNS provider so players connect by name only.
DOMAIN_BASE=""                 # e.g. "aether.host"
DNS_PROVIDER="none"            # "cloudflare" | "none"
CLOUDFLARE_API_TOKEN=""        # token with DNS:Edit on the zone
CLOUDFLARE_ZONE_ID=""          # the zone id for DOMAIN_BASE

# === CurseForge (optional) ===
# An API key (https://console.curseforge.com) enables the CurseForge content source.
CURSEFORGE_API_KEY=""

# === Monitoring (optional) ===
# Discord webhook URL — operational alerts (node down, server crash) are posted here.
ALERT_WEBHOOK=""

# === Anti-DDoS (edge proxy guard) ===
# Per-IP limits enforced by the wake-on-join edge proxy on game traffic.
DDOS_MAX_CONN_PER_IP="8"     # max concurrent connections per source IP
DDOS_CONN_PER_MIN="40"       # max new connections per IP per minute
DDOS_PING_PER_MIN="60"       # max server-list pings per IP per minute
DDOS_BAN_STRIKES="10"        # bad/aborted handshakes before a temp ban
DDOS_BAN_SECONDS="600"       # temp-ban duration
DDOS_HANDSHAKE_MS="4000"     # drop connections that don't handshake in time (slow-loris)
DDOS_BLOCKLIST=""            # comma-separated IPs to always reject
PROXY_PROTOCOL="0"           # set 1 if behind an upstream that sends PROXY protocol v1

# === DuckDNS — stable address that follows your home IP (optional) ===
# DUCKDNS_DOMAIN is the label only, e.g. "aether" for aether.duckdns.org.
DUCKDNS_DOMAIN=""
DUCKDNS_TOKEN=""

# === Discord control bot (apps/discord-bot, opt-in profile "discord") ===
# Discord application — https://discord.com/developers (bot token + application id)
DISCORD_TOKEN=""
DISCORD_CLIENT_ID=""
# An Aether API key (panel → Account → API keys, "aeth_…") the bot uses to call the API.
# Needs scopes: allocation.read, players.read, control.start, control.stop, control.command, backup.create
AETHER_API_KEY=""

# === AI Server Copilot (optional) ===
# An Anthropic API key (https://console.anthropic.com) unlocks full AI answers in
# the per-server Copilot tab. Left empty, the Copilot still works using a built-in
# rule-based helper (no AI). Never crashes the panel when unset.
ANTHROPIC_API_KEY=""
